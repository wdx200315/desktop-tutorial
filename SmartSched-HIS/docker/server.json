  "business": {
    "queue_capacity": 2000,
    "max_wait_time": 120,
    "call_timeout": 300,
    "auto_reassign": true
  },
  "monitoring": {
    "enabled": true,
    "port": 8889,
    "stats_interval": 60
  }
