{
  "server": {
    "host": "0.0.0.0",
    "port": 8888,
    "thread_pool_size": 8,
    "max_connections": 1024
  },
  "database": {
    "host": "mysql",
    "port": 3306,
    "name": "smartsched",
    "user": "smartsched",
    "password": "smartsched_password",
    "pool_size": 20
  },
