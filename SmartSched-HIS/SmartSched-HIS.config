# SmartSched-HIS Qt Creator项目配置
# 将此文件放在项目根目录，Qt Creator会自动识别

# 项目配置
PROJECT_NAME = SmartSched-HIS
PROJECT_VERSION = 1.0.0

# CMake配置
CMAKE_PROJECT = True

# 源文件目录
SOURCE_DIRS = common server client tools tests doc

# 包含目录
INCLUDEPATH = common/include server/include client/include

# Qt模块
QT += core network qml quick quickcontrols2 widgets

# 构建选项
CONFIG += c++17
CONFIG += qt
